{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "sandbox-token-12345"
    },
    "tailscale": {
      "mode": "off"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  "models": {
    "providers": {
      "chutes": {
        "baseUrl": "${CLAWBENCH_LLM_BASE_URL}",
        "api": "openai-completions",
        "apiKey": "${CLAWBENCH_LLM_API_KEY}",
        "models": [
          {
            "id": "zai-org/GLM-5-TEE",
            "name": "GLM-5-TEE (Chutes)",
            "cost": {
              "input": 1.00,
              "output": 3.20,
              "cacheRead": 0.10,
              "cacheWrite": 0.10
            }
          }
        ]
      },
      "zhipu": {
        "baseUrl": "${CLAWBENCH_LLM_BASE_URL}",
        "api": "openai-completions",
        "apiKey": "${CLAWBENCH_LLM_API_KEY}",
        "models": [
          {
            "id": "glm-5",
            "name": "GLM-5",
            "cost": {
              "input": 1.00,
              "output": 3.20,
              "cacheRead": 0.10,
              "cacheWrite": 0.10
            }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "model": {
        "primary": "${CLAWBENCH_DEFAULT_MODEL}"
      }
    }
  },
  "plugins": {
    "slots": {
      "memory": "none"
    },
    "entries": {
      "clawbench-tools": {
        "enabled": true,
        "config": {
          "mockServerUrl": "http://mock-tools:3001",
          "scenario": "default"
        }
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": false
      },
      "fetch": {
        "enabled": false
      }
    },
    "deny": [
      "process",
      "browser",
      "canvas",
      "nodes",
      "cron",
      "gateway",
      "apply_patch"
    ],
    "allow": [
      "exec",
      "slack",
      "memory_search",
      "memory_get",
      "web_search",
      "read",
      "session_status"
    ]
  },
  "channels": {}
}
